# Postgres connection string (Neon recommended). Use a pooled connection string.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Random 32+ byte secret used by Better Auth to sign sessions.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Base URL of the app for Better Auth. Defaults to http://localhost:3000 in dev.
BETTER_AUTH_URL="http://localhost:3000"

# --- Transactional email (password reset) ---
# Resend API key. Get one at https://resend.com/api-keys (free tier works).
# If unset, password-reset emails are skipped (the link is still logged to the
# server console for local development).
RESEND_API_KEY=""

# Sender address for outgoing email. Must be a Resend-verified domain in
# production; the onboarding@resend.dev sandbox only delivers to your own
# account email. Format: "Name <address>".
EMAIL_FROM="Momentum <onboarding@resend.dev>"

# --- AI Planner (optional) ---
# Google Gemini API key (free tier works). Get one at https://aistudio.google.com/apikey
# If unset, the AI Planner falls back to a transparent heuristic planner so the
# feature still works end-to-end without a key.
GEMINI_API_KEY=""

# Override the planning model. Defaults to gemini-2.5-flash.
GEMINI_MODEL="gemini-2.5-flash"
