# Postgres connection string (Neon recommended). Use a pooled connection string.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Random 32+ byte secret used by Better Auth to sign sessions.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Base URL of the app for Better Auth. Defaults to http://localhost:3000 in dev.
BETTER_AUTH_URL="http://localhost:3000"

# --- AI Planner (optional) ---
# Google Gemini API key (free tier works). Get one at https://aistudio.google.com/apikey
# If unset, the AI Planner falls back to a transparent heuristic planner so the
# feature still works end-to-end without a key.
GEMINI_API_KEY=""

# Override the planning model. Defaults to gemini-2.5-flash.
GEMINI_MODEL="gemini-2.5-flash"
